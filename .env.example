# Jantar — Environment Configuration
# Copy to .env and fill in values

# === VM Infrastructure ===
VM_HOST=
VM_USER=ubuntu
VM_SSH_KEY=
# SSH tunnel: ssh -i $VM_SSH_KEY -L 5901:localhost:5901 $VM_USER@$VM_HOST

# === Sarvam AI (required — get key at https://sarvam.ai) ===
SARVAM_API_KEY=

# === data.gov.in (optional — register free at https://data.gov.in) ===
DATA_GOV_API_KEY=

# === Qdrant (Vector DB on VM or local Docker) ===
QDRANT_URL=http://localhost:6333

# === Server ===
HOST=0.0.0.0
PORT=8000

# === API Auth key for the REST endpoint ===
API_KEY=
